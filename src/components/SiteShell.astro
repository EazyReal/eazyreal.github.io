---
import SiteNav from "./SiteNav.astro";
import SocialLinks from "./SocialLinks.astro";
import { links, siteMeta } from "../data/siteContent";
---

<div class="ml-4 w-[calc(100%-2rem)] py-6 md:ml-12 md:w-[min(690px,calc(100%-6rem))] md:py-11">
  <header class="mb-7 block md:flex md:items-start md:justify-between md:gap-6">
    <div>
      <a
        class="block font-serif text-[30px] leading-none no-underline"
        href={links.home.href}
        aria-label={`${siteMeta.name} home`}
      >
        {siteMeta.name}
      </a>
      <SocialLinks />
    </div>
    <div class="mt-5 md:mt-0">
      <SiteNav />
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="mt-12 border-t border-ink pt-5">
    <SocialLinks />
  </footer>
</div>
