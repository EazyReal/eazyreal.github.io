---
import { socialLinks } from "../data/siteContent";
---

<nav class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-muted" aria-label="External links">
  {
    socialLinks.map((link) => (
      <a
        class="underline decoration-1 underline-offset-[6px] hover:decoration-2"
        href={link.href}
      >
        {link.label}
      </a>
    ))
  }
</nav>
