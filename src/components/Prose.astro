---
const proseClass = [
  "prose",
  "prose-sm",
  "max-w-none",
  "prose-neutral",
  "[overflow-wrap:anywhere]",
  "prose-p:text-ink",
  "prose-p:[overflow-wrap:anywhere]",
  "prose-li:text-ink",
  "prose-li:[overflow-wrap:anywhere]",
  "prose-strong:text-ink",
  "prose-strong:[overflow-wrap:anywhere]",
  "prose-a:text-ink",
  "prose-a:[overflow-wrap:anywhere]",
  "prose-a:underline",
  "prose-a:decoration-1",
  "prose-a:underline-offset-[6px]",
  "hover:prose-a:decoration-2",
  "prose-headings:font-mono",
  "prose-headings:text-ink",
  "prose-headings:text-sm",
  "prose-headings:leading-[1.3]",
  "prose-h1:font-serif",
  "prose-h1:text-[32px]",
  "prose-h1:font-normal",
  "prose-h1:leading-tight",
  "prose-h1:mb-5",
  "prose-h2:mt-8",
  "prose-h2:mb-3",
  "prose-h3:mt-6",
  "prose-h3:mb-2",
  "prose-ul:pl-5",
  "prose-ol:pl-5",
  "prose-li:my-1",
  "prose-hr:border-line",
  "prose-blockquote:border-line",
  "prose-blockquote:text-muted",
  "prose-code:bg-paper-dark",
  "prose-code:px-1",
  "prose-code:py-0",
  "prose-code:font-normal",
  "prose-pre:border",
  "prose-pre:border-line",
  "prose-pre:bg-white",
  "prose-pre:text-ink",
  "prose-pre:shadow-none",
  "prose-img:mx-auto",
  "prose-table:text-[13px]",
  "prose-th:border",
  "prose-th:border-line",
  "prose-td:border",
  "prose-td:border-line",
].join(" ");
---

<article class={proseClass}>
  <slot />
</article>
