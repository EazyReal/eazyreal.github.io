---
import { links } from "../data/siteContent";

const target = links.writingTags.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting to Writing Tags</title>
  </head>
  <body>
    <p><a href={target}>Writing {links.writingTags.label}</a></p>
  </body>
</html>
