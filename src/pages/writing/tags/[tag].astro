---
import ArticleLayout from "../../../layouts/ArticleLayout.astro";
import { links, pageMeta } from "../../../data/siteContent";
import { latestLastUpdated, tagFacets } from "../../../data/writingIndex";
import { formatDisplayDate } from "../../../utils/dates";

export function getStaticPaths() {
  return tagFacets.map((tag) => ({
    params: { tag: tag.slug },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const frontmatter = {
  ...pageMeta.writing,
  title: `${pageMeta.writing.title}: ${tag.label}`,
  heading: tag.label,
  lastUpdated: latestLastUpdated(tag.entries) ?? pageMeta.writing.lastUpdated,
  tags: ["writing", tag.label],
};
---

<ArticleLayout frontmatter={frontmatter}>
  <p>
    <a href={links.writing.href}>{links.writing.label}</a> / <a href={links.writingTags.href}>
      {links.writingTags.label}
    </a>
  </p>

  <ul>
    {
      tag.entries.map((entry) => (
        <li>
          <a href={entry.href}>{entry.title}</a>
          {entry.description && <> - {entry.description}</>}
          <br />
          <span class="text-muted">
            {entry.kind}
            {entry.lastUpdated && (
              <>
                {" "}
                · updated <time datetime={entry.lastUpdated}>{formatDisplayDate(entry.lastUpdated)}</time>
              </>
            )}
          </span>
        </li>
      ))
    }
  </ul>
</ArticleLayout>
