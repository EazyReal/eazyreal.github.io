---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { areaFacets, isTopicTag } from "../../data/writingIndex";

export function getStaticPaths() {
  return areaFacets.map((area) => ({
    params: { section: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const frontmatter = { title: `Writing: ${area.label}`, tags: ["writing", area.label] };
---

<ArticleLayout frontmatter={frontmatter}>
  <h1>{area.label}</h1>

  <p>
    <a href="/writing/">Writing</a>
  </p>

  <ul>
    {
      area.entries.map((entry) => (
        <li>
          <a href={entry.href}>{entry.title}</a>
          {entry.description && <> - {entry.description}</>}
          <br />
          <span class="text-muted">
            {entry.kind} ·{" "}
            {entry.tags.filter(isTopicTag).map((tag, index) => (
              <>
                {index > 0 && " · "}
                <a href={tag.href}>{tag.label}</a>
              </>
            ))}
          </span>
        </li>
      ))
    }
  </ul>
</ArticleLayout>
