---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { courseworkGroups, links, pageMeta } from "../../data/siteContent";

const frontmatter = pageMeta.coursework;
---

<ArticleLayout frontmatter={frontmatter}>
  <p>
    <a href={links.writing.href}>{links.writing.label}</a>
  </p>

  <ul>
    {
      courseworkGroups.map((group) => (
        <li>
          <strong>{group.title}</strong>
          {" - "}
          {group.description}
          <br />
          <span class="text-muted">
            {group.links.map((link, index) => (
              <>
                {index > 0 && " · "}
                <a href={link.href}>{link.label}</a>
              </>
            ))}
          </span>
        </li>
      ))
    }
  </ul>
</ArticleLayout>
