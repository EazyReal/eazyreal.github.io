---
import ArticleLayout from "../layouts/ArticleLayout.astro";
import { ossGroups, pageMeta } from "../data/siteContent";

const frontmatter = pageMeta.oss;
---

<ArticleLayout frontmatter={frontmatter}>
  <p>Selected merged PRs to open-source systems I use for RL infrastructure and software-engineering agent training.</p>

  {
    ossGroups.map((group) => (
      <>
        <h2 id={group.id}>{group.name}</h2>
        <ul>
          {
            group.contributions.map((contribution) => (
              <li>
                <a href={contribution.href}>{contribution.title}</a> - {contribution.description}
              </li>
            ))
          }
        </ul>
      </>
    ))
  }
</ArticleLayout>
