---
import "katex/dist/katex.min.css";
import "../styles/global.css";
import SiteShell from "../components/SiteShell.astro";
import { siteMeta } from "../data/siteContent";

const {
  title = siteMeta.name,
  description = siteMeta.description,
  lastUpdated,
} = Astro.props;

const pageTitle = title === siteMeta.name ? title : `${title} | ${siteMeta.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={siteMeta.author} />
    {lastUpdated && <meta property="article:modified_time" content={lastUpdated} />}
    <link rel="icon" href="/img/favicon.ico" />
    <title>{pageTitle}</title>
  </head>
  <body class="overflow-x-hidden bg-paper font-mono text-sm leading-[1.45] text-ink">
    <SiteShell>
      <slot />
    </SiteShell>
  </body>
</html>
